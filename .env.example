# ─────────────────────────────────────────────────────────────────
# LLM API KEYS
# Get these from the websites below — they're free to sign up.
# ─────────────────────────────────────────────────────────────────

# OpenAI API Key
# Where to get it: https://platform.openai.com/api-keys
# Click "Create new secret key". Copy it immediately — it's shown once.
# Cost: ~$0.15 per million input tokens for gpt-4o-mini (very cheap)
# Used for: GPT answer generation AND text-embedding-3-small embeddings
OPENAI_API_KEY=your_openai_key_here

# Groq API Key
# Where to get it: https://console.groq.com → "Create API Key"
# Groq is COMPLETELY FREE for development use.
# Models available: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
# Recommended: start with Groq to avoid OpenAI costs during development
GROQ_API_KEY=your_groq_key_here

# ─────────────────────────────────────────────────────────────────
# PROVIDER SELECTION
# Change these to switch between providers without touching code
# ─────────────────────────────────────────────────────────────────

# Which LLM to use for answer generation
# Options: "openai" | "groq"
# Recommendation: "groq" for development (free), "openai" for production
LLM_PROVIDER=groq

# Which embedding model to use (converts text to vectors)
# Options: "openai" | "local"
# "openai" uses text-embedding-3-small (1536 dims, costs ~$0.02/million tokens)
# "local" uses all-MiniLM-L6-v2 from HuggingFace (384 dims, completely FREE)
# Recommendation: "local" for development
EMBEDDING_PROVIDER=local

# ─────────────────────────────────────────────────────────────────
# STORAGE PATHS
# Where data is saved on your disk
# ─────────────────────────────────────────────────────────────────

# Where ChromaDB saves its files (vector embeddings)
# This folder is auto-created. It persists between app restarts.
CHROMA_DB_PATH=./chroma_db

# Where BM25 index files are saved (keyword search index)
BM25_INDEX_PATH=./bm25_index

# ─────────────────────────────────────────────────────────────────
# RETRIEVAL SETTINGS
# Tune these to balance quality vs. speed vs. cost
# ─────────────────────────────────────────────────────────────────

# How many chunks to retrieve from each retriever (BM25 and vector)
# before reranking. Higher = better recall, slower speed.
# Sweet spot: 15-25
RETRIEVAL_TOP_K=20

# How many chunks to keep AFTER reranking to send to the LLM.
# Higher = more context for LLM, higher token cost.
# Sweet spot: 4-6
RERANK_TOP_K=5

# ─────────────────────────────────────────────────────────────────
# QUALITY THRESHOLDS
# ─────────────────────────────────────────────────────────────────

# Minimum citation coverage score (0.0 to 1.0).
# Below this threshold, the answer is flagged as potentially unreliable.
# 0.7 means at least 70% of claims must have valid citations.
MIN_CITATION_SCORE=0.7