# ═══════════════════════════════════════════════════════
# PYTHON BYTECODE
# Python compiles .py files to .pyc for speed.
# These are auto-generated and don't belong in git.
# ═══════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ═══════════════════════════════════════════════════════
# VIRTUAL ENVIRONMENT
# The venv/ folder contains a full Python installation (100MB+).
# Never commit this — it's machine-specific and regenerated via:
# pip install -r requirements.txt
# ═══════════════════════════════════════════════════════
venv/
env/
.venv/
ENV/

# ═══════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — MOST CRITICAL GITIGNORE ENTRY
# .env contains your API keys. If this file is committed,
# anyone with repo access can steal your keys and rack up
# thousands of dollars in API charges.
# The .env.example file IS committed (it has no real keys).
# ═══════════════════════════════════════════════════════
.env

# ═══════════════════════════════════════════════════════
# GENERATED DATA STORES
# These folders are auto-created when the app runs.
# They can be gigabytes in size and change every time you
# upload a new document. Regenerated by re-uploading docs.
# ═══════════════════════════════════════════════════════
chroma_db/
bm25_index/

# ═══════════════════════════════════════════════════════
# TEST ARTIFACTS
# Generated by pytest — not source code.
# ═══════════════════════════════════════════════════════
.coverage
htmlcov/
.pytest_cache/
*.coverage

# ═══════════════════════════════════════════════════════
# IDE CONFIGURATION
# Editor settings are personal preference.
# They often cause conflicts between team members.
# ═══════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════
# OPERATING SYSTEM FILES
# Mac and Windows create hidden management files.
# ═══════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ═══════════════════════════════════════════════════════
# BUILD ARTIFACTS
# Generated when packaging Python projects for distribution.
# ═══════════════════════════════════════════════════════
dist/
build/
*.egg-info/
*.egg

# ═══════════════════════════════════════════════════════
# JUPYTER NOTEBOOKS (if you experiment there)
# ═══════════════════════════════════════════════════════
.ipynb_checkpoints/

# ═══════════════════════════════════════════════════════
# UPLOADED DOCUMENTS (user data, too large for git)
# ═══════════════════════════════════════════════════════
data/uploads/
*.pdf
*.docx
# Exception: keep the sample document for testing
!data/sample_docs/sample.pdf

